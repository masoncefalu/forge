# PennyForge local MVP environment
# SQLite database file (relative to prisma/ directory)
DATABASE_URL="file:./dev.db"

# ─────────────────────────────────────────────────────────────────────────────
# Production placeholders (COMMENTED — local dev needs none of these).
# These document the env vars the deployment/backend/mobile tooling expects.
# Set the real values in the relevant dashboard, NEVER commit them here.
# See docs/tooling-options.md for what each one is and where it belongs.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase / Postgres (Phase 1 — swaps the datasource provider to postgresql).
# Prisma needs the pooled URL for the app and the direct URL for migrations.
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Supabase client (only if you use supabase-js for auth/storage from the client).
# NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_ANON_KEY"
# SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY"   # server-only, never client

# Sentry (error/crash monitoring for web/backend).
# NEXT_PUBLIC_SENTRY_DSN="https://YOUR_KEY@oXXXX.ingest.sentry.io/XXXX"
# SENTRY_AUTH_TOKEN="YOUR_AUTH_TOKEN"                 # build-time only, for source maps
# SENTRY_ORG="pennyforge"
# SENTRY_PROJECT="pennyforge-web"

# Capacitor native shell — the hosted URL the iOS app points at.
# CAPACITOR_SERVER_URL="https://pennyforge.vercel.app"

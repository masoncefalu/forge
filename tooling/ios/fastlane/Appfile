# PennyForge — Fastlane Appfile (TEMPLATE).
# Sensitive identifiers (Apple ID, team ID) are env-only — nothing secret is
# committed to git. app_identifier defaults to the public bundle ID below so
# the template works out of the box; override APP_IDENTIFIER to change it.

app_identifier(ENV["APP_IDENTIFIER"] || "com.pennyforge.app")
apple_id(ENV["FASTLANE_APPLE_ID"])       # Apple ID email (only used for Apple-ID auth fallback)
team_id(ENV["DEVELOPER_TEAM_ID"])        # Apple Developer Program team ID (10 chars)
itc_team_id(ENV["ASC_TEAM_ID"])          # App Store Connect team ID (optional if single team)
